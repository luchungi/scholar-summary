{
  "arxiv.org": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://arxiv\\.org/(abs|html)/(?P<id>[^/]+)",
        "replacement": "https://arxiv.org/pdf/{id}"
      }
    ]
  },
  "biorxiv.org": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://(?:www\\.)?biorxiv\\.org/content/(?P<doi>10\\.1101/\\d{4}\\.\\d{2}\\.\\d{2}\\.\\d+v?\\d*)",
        "replacement": "https://www.biorxiv.org/content/{doi}.full.pdf"
      }
    ]
  },
  "medrxiv.org": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://(?:www\\.)?medrxiv\\.org/content/(?P<doi>10\\.1101/\\d{4}\\.\\d{2}\\.\\d{2}\\.\\d+v?\\d*)",
        "replacement": "https://www.medrxiv.org/content/{doi}.full.pdf"
      }
    ]
  },
  "openreview.net": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://openreview\\.net/forum\\?id=(?P<id>[^&]+)",
        "replacement": "https://openreview.net/pdf?id={id}"
      }
    ]
  },
  "nature.com": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://(?:www\\.)?nature\\.com/articles/(?P<id>s[a-z0-9-]+)",
        "replacement": "https://www.nature.com/articles/{id}.pdf"
      }
    ]
  },
  "link.springer.com": {
    "rules": [
      {
        "type": "regex_replace",
        "pattern": "^https?://link\\.springer\\.com/article/(?P<id>.+)",
        "replacement": "https://link.springer.com/content/pdf/{id}_reference.pdf"
      }
    ]
  },
  "sciencedirect.com": {
    "rules": [
      {
        "type": "none"
      }
    ]
  },
  "ieeexplore.ieee.org": {
    "rules": [
      {
        "type": "none"
      }
    ]
  },
  "jmsrr.com": {
    "rules": [
      {
        "type": "direct"
      }
    ]
  },
  "researchgate.net": {
    "rules": [
      {
        "type": "direct"
      }
    ]
  },
  "pm-research.com": {
    "rules": [
      {
        "type": "none"
      }
    ]
  },
  "arcengkongre.com": {
    "rules": [
      {
        "type": "direct"
      }
    ]
  },
  "ui.adsabs.harvard.edu": {
    "rules": [
      {
        "type": "none"
      }
    ]
  },
  "jfr.ut.ac.ir": {
    "rules": [
      {
        "type": "css_selector",
        "selector": "a[href*='.pdf']",
        "attribute": "href"
      }
    ]
  },
  "helda.helsinki.fi": {
    "rules": [
      {
        "type": "direct"
      }
    ]
  },
  "svedbergopen.com": {
    "rules": [
      {
        "type": "none"
      }
    ]
  },
  "aclanthology.org": {
    "rules": [
      {
        "type": "direct"
      }
    ]
  }
}